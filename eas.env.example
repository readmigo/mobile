# EAS submit secrets — register via `eas secret:create --scope project --name <KEY> --value <value>`
# These are NOT loaded by the app at runtime; they are referenced by eas.json submit.production.ios.
EAS_SUBMIT_APPLE_ID=your-real-apple-id@example.com
EAS_SUBMIT_ASC_APP_ID=1234567890

# RevenueCat public SDK keys — register via `eas secret:create --scope project --name <KEY> --value <value>`
# Copy from RevenueCat Dashboard → Project Settings → API Keys → Public SDK Keys
EAS_PUBLIC_REVENUECAT_IOS=appl_xxxxxxxxxxxxxxxx
EAS_PUBLIC_REVENUECAT_ANDROID=goog_xxxxxxxxxxxxxxxx
