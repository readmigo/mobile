{
  "root": true,
  "extends": ["eslint:recommended"],
  "env": {
    "es6": true,
    "node": true,
    "browser": true
  },
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": { "jsx": true }
  },
  "globals": {
    "__DEV__": "readonly",
    "React": "readonly"
  },
  "rules": {
    "no-unused-vars": "off",
    "no-undef": "off",
    "no-restricted-imports": ["error", {
      "patterns": [{
        "group": [
          "@/features/*/components/*",
          "@/features/*/hooks/*",
          "@/features/*/services/*",
          "@/features/*/stores/*",
          "@/features/*/types/*",
          "@/features/*/theme/*"
        ],
        "message": "Import from the feature facade: @/features/<name>. See src/features/README.md"
      }]
    }]
  },
  "overrides": [
    {
      "files": ["**/__tests__/**/*.{ts,tsx}", "**/*.test.{ts,tsx}", "**/*.spec.{ts,tsx}", "jest.setup.js"],
      "env": { "jest": true }
    }
  ],
  "ignorePatterns": ["dist", "node_modules", "coverage", "ios", "android", "native-modules", ".expo"]
}
