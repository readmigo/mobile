{
  "name": "@readmigo/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "jest --forceExit",
    "prebuild": "expo prebuild --clean",
    "build:ios": "cd ios && xcodebuild -workspace Readmigo.xcworkspace -scheme Readmigo -configuration Release -sdk iphoneos archive -archivePath build/Readmigo.xcarchive",
    "build:android": "cd android && ./gradlew assembleRelease",
    "codegen": "npx react-native codegen",
    "pod-install": "cd ios && bundle exec pod install",
    "ota:patch": "npx shorebird patch --platform=all",
    "ota:release": "npx shorebird release --platform=all"
  },
  "jest-junit": {
    "outputDirectory": "coverage",
    "outputName": "junit.xml",
    "ancestorSeparator": " › ",
    "classNameTemplate": "{classname}",
    "titleTemplate": "{title}"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/bottom-tabs": "^7.9.0",
    "@react-navigation/native": "^7.1.26",
    "@react-navigation/native-stack": "^7.9.0",
    "@sentry/react-native": "^8.6.0",
    "@shopify/flash-list": "^2.2.0",
    "@tanstack/react-query": "^5.90.12",
    "axios": "^1.13.2",
    "babel-preset-expo": "^54.0.9",
    "drizzle-orm": "^0.45.1",
    "expo": "~54.0.30",
    "expo-apple-authentication": "^8.0.8",
    "expo-application": "~7.0.8",
    "expo-auth-session": "^7.0.10",
    "expo-av": "~16.0.8",
    "expo-constants": "~18.0.12",
    "expo-crypto": "^15.0.8",
    "expo-device": "~8.0.10",
    "expo-document-picker": "^55.0.9",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~0.32.15",
    "expo-router": "~6.0.21",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "i18next": "^25.7.3",
    "immer": "^11.1.0",
    "lottie-react-native": "^7.3.4",
    "posthog-react-native": "^4.37.6",
    "react": "19.1.0",
    "react-i18next": "^16.5.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-pager-view": "^8.0.0",
    "react-native-purchases": "10.1.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-tab-view": "^4.2.2",
    "react-native-toast-message": "^2.3.3",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "^0.7.1",
    "react-native-worklets-core": "^1.6.2",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "axios-mock-adapter": "^1.22.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "jest-junit": "^16.0.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli"
    ]
  }
}
